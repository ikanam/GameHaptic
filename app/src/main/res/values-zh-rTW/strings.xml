    <string name="permission_audio_title">錄音 / 播放擷取</string>
    <string name="permission_audio_description">用於透過系統 AudioPlaybackCapture 擷取遊戲聲音；不會錄製麥克風語音。</string>
    <string name="permission_overlay_title">隱形懸浮窗保活</string>
    <string name="permission_overlay_description">用於建立透明保活視窗，協助 App 在遊戲背景持續執行；不會顯示在螢幕上。</string>
    <string name="permission_notification_title">前景服務通知</string>
    <string name="permission_notification_description">Android 要求持續擷取音訊時顯示常駐通知，用來避免背景服務被系統靜默停止。</string>
    <string name="permission_granted">已允許</string>
    <string name="permission_pending">待授權</string>

    <string name="tuning_title">震感調校</string>
    <string name="tuning_noise_gate_title">靜音門檻</string>
    <string name="tuning_noise_gate_description">越高越能忽略環境底噪、低音量音樂和細碎聲音；太高會漏掉細微震感。</string>
    <string name="tuning_sensitivity_title">震動靈敏度</string>
    <string name="tuning_sensitivity_description">控制整體震動強弱和觸發積極程度；越高越容易把聲音變成明顯震動。</string>
    <string name="tuning_music_filter_title">音樂過濾</string>
    <string name="tuning_music_filter_description">越高越偏向槍聲、爆炸、碰撞這類瞬間衝擊；越低越會跟隨持續音樂和低頻節奏。</string>

