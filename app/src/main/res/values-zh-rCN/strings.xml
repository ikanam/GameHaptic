    <string name="permission_audio_title">录音 / 播放捕获</string>
    <string name="permission_audio_description">用于通过系统的 AudioPlaybackCapture 捕获游戏声音；不会录制麦克风说话声。</string>
    <string name="permission_overlay_title">隐形悬浮窗保活</string>
    <string name="permission_overlay_description">用于创建一个透明保活窗口，帮助 App 在游戏后台持续运行；不会显示在屏幕上。</string>
    <string name="permission_notification_title">前台服务通知</string>
    <string name="permission_notification_description">Android 要求持续捕获音频时显示常驻通知，用来避免后台服务被系统静默停止。</string>
