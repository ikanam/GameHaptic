    <string name="tuning_title">震感调校</string>
    <string name="tuning_noise_gate_title">静音门限</string>
    <string name="tuning_noise_gate_description">越高越能忽略环境底噪、低音量音乐和细碎声音；太高会漏掉轻微震感。</string>
    <string name="tuning_sensitivity_title">震动灵敏度</string>
    <string name="tuning_sensitivity_description">控制整体震动强弱和触发积极程度；越高越容易把声音变成明显震动。</string>
    <string name="tuning_music_filter_title">音乐过滤</string>
    <string name="tuning_music_filter_description">越高越偏向枪声、爆炸、碰撞这类瞬间冲击；越低越会跟随持续音乐和低频节奏。</string>

