    <string name="tuning_noise_gate_title">Silence gate</string>
    <string name="tuning_noise_gate_description">Higher values ignore floor noise, quiet music, and small sounds. Too high may miss subtle haptics.</string>
    <string name="tuning_sensitivity_title">Haptic sensitivity</string>
    <string name="tuning_sensitivity_description">Controls overall haptic strength and trigger aggressiveness. Higher values turn more audio into noticeable vibration.</string>
    <string name="tuning_music_filter_title">Music filter</string>
    <string name="tuning_music_filter_description">Higher values favor instant impacts such as gunfire, explosions, and collisions. Lower values follow sustained music and bass rhythm.</string>

