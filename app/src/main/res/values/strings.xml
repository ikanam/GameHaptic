    <string name="permission_audio_description">Captures game audio through Android AudioPlaybackCapture. Microphone speech is not recorded.</string>
    <string name="permission_overlay_title">Invisible overlay keep-alive</string>
    <string name="permission_overlay_description">Creates a transparent keep-alive window so the app can continue running behind a game. Nothing is shown on screen.</string>
    <string name="permission_notification_title">Foreground service notification</string>
    <string name="permission_notification_description">Android requires a persistent notification while audio capture is running, helping prevent the system from silently stopping the service.</string>
